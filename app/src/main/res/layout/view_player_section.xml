<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp">

    <ImageView
        android:id="@+id/ic_player"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:contentDescription="@string/icon_of_the_player"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/ic_player" />

    <TextView
        android:id="@+id/tv_playerNameLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:text="@string/player_name"
        android:textSize="20sp"
        app:layout_constraintStart_toEndOf="@+id/ic_player"
        app:layout_constraintTop_toTopOf="@+id/ic_player" />

    <TextView
        android:id="@+id/tv_playerNameValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        app:layout_constraintStart_toStartOf="@+id/tv_playerNameLabel"
        app:layout_constraintTop_toBottomOf="@+id/tv_playerNameLabel"
        tools:text="Player Name" />

    <androidx.constraintlayout.helper.widget.Flow
        android:id="@+id/flow_player"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:constraint_referenced_ids="bt_win1,bt_win3,bt_win6,bt_win9,bt_win12"
        app:flow_horizontalGap="20dp"
        app:flow_horizontalStyle="packed"
        app:flow_verticalGap="4dp"
        app:flow_wrapMode="aligned"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_playerNameValue" />

    <Button
        android:id="@+id/bt_win1"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:insetLeft="0dp"
        android:insetTop="0dp"
        android:insetRight="0dp"
        android:insetBottom="0dp"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:padding="0dp"
        android:text="@string/_1"
        android:textSize="14sp"
        app:cornerRadius="8dp" />

    <Button
        android:id="@+id/bt_win3"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:insetLeft="0dp"
        android:insetTop="0dp"
        android:insetRight="0dp"
        android:insetBottom="0dp"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:padding="0dp"
        android:text="@string/truco_3"
        android:textSize="14sp"
        app:cornerRadius="8dp" />

    <Button
        android:id="@+id/bt_win6"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:insetLeft="0dp"
        android:insetTop="0dp"
        android:insetRight="0dp"
        android:insetBottom="0dp"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:padding="0dp"
        android:text="@string/truco_6"
        android:textSize="14sp"
        app:cornerRadius="8dp" />

    <Button
        android:id="@+id/bt_win9"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:insetLeft="0dp"
        android:insetTop="0dp"
        android:insetRight="0dp"
        android:insetBottom="0dp"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:padding="0dp"
        android:text="@string/truco_9"
        android:textSize="14sp"
        app:cornerRadius="8dp" />

    <Button
        android:id="@+id/bt_win12"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:insetLeft="0dp"
        android:insetTop="0dp"
        android:insetRight="0dp"
        android:insetBottom="0dp"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:padding="0dp"
        android:text="@string/truco_12"
        android:textSize="14sp"
        app:cornerRadius="8dp" />

</androidx.constraintlayout.widget.ConstraintLayout>